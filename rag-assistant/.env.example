# ===========================================
# RAG Assistant - Environment Configuration
# ===========================================

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/rag_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag_assistant

# Admin Authentication
ADMIN_PASSWORD=admin123

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Chunking Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval Configuration
TOP_K=5
SIMILARITY_THRESHOLD=0.3

# Application
BACKEND_PORT=8000
FRONTEND_PORT=3000
DEBUG=false

# Cost Estimation (USD per 1K tokens)
COST_INPUT_PER_1K=0.00015
COST_OUTPUT_PER_1K=0.0006
COST_EMBEDDING_PER_1K=0.00002
